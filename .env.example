# ─── Base de données ──────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pressingDB?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=changez_ce_secret_en_production
JWT_EXPIRES_IN=7d

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS (origines autorisees, separees par virgule, ou * pour tout) ─────────
ALLOWED_ORIGINS=*
